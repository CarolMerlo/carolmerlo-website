{
  "name": "carolmerlo-com",
  "private": true,
  "scripts": {
    "lint:html": "html-validate \"*.html\" \"*/index.html\"",
    "lint:css":  "stylelint \"assets/css/**/*.css\"",
    "lint:js":   "eslint \"assets/js/**/*.js\"",
    "lint":      "npm run lint:html && npm run lint:css && npm run lint:js",
    "serve":     "http-server . -p 8080 --silent",
    "lighthouse": "lhci autorun"
  },
  "devDependencies": {
    "@lhci/cli": "^0.14.0",
    "eslint": "^9.0.0",
    "globals": "^15.0.0",
    "html-validate": "^9.0.0",
    "http-server": "^14.0.0",
    "stylelint": "^16.0.0",
    "stylelint-config-standard": "^36.0.0"
  }
}
